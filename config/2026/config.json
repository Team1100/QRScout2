  "sections": [
    {
      "name": "Prematch",
      "fields": [
        {
          "title": "Scouter Initials",
          "description": "Enter the initials of the scouter.",
          "type": "text",
          "required": true,
          "code": "scouter",
          "formResetBehavior": "preserve",
          "defaultValue": ""
        },
        {
          "title": "Match Number",
          "description": "Enter the match number.",
          "type": "number",
          "required": true,
          "code": "matchNumber",
          "formResetBehavior": "increment",
          "defaultValue": 1
        },
        {
          "title": "Team Number",
          "description": "The team number of the robot you're scouting.",
          "type": "number",
          "required": true,
          "code": "teamNumber",
          "formResetBehavior": "reset",
          "defaultValue": 0,
          "min": 0,
          "max": 99999
        },
        {
          "title": "Match Prediction!",
          "description": "Who do you think will win the match? (pls dont change this after the match is over)",
          "type": "select",
          "required": true,
          "code": "Prediction",
          "formResetBehavior": "reset",
          "defaultValue": "No Prediction",
          "choices": {
            "No Prediction": "No Prediction",
            "Red": "Red",
            "Blue": "Blue"
          }
        },
        {
          "title": "No Show",
          "description": "Check if the robot did not show up for the match.",
          "type": "boolean",
          "required": false,
          "code": "noShow",
          "formResetBehavior": "reset",
          "defaultValue": false
        }
      ]
    },
    {
      "name": "Auto",
      "color": "#3b82f6",
      "fields": [
        {
          "title": "Hub Fuel",
          "type": "multi-counter",
          "required": false,
          "code": "hubAuto",
          "formResetBehavior": "reset",
          "defaultValue": 0
        },
        {
          "title": "Ferried Fuel",
          "type": "multi-counter",
          "required": false,
          "code": "ferAuto",
          "formResetBehavior": "reset",
          "defaultValue": 0
        },
        {
          "title": "Auto Climb Position",
          "type": "select",
          "required": true,
          "code": "climbauto",
          "formResetBehavior": "reset",
          "defaultValue": "No Climb",
          "choices": {
            "No Climb": "No Climb",
            "Left": "Left",
            "Middle": "Middle",
            "Right": "Right"
          }
        },
        {
          "title": "Climbed Successfully?",
          "description": "Did the robot get off the gound?",
          "type": "boolean",
          "required": false,
          "code": "noShow",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Accuracy?",
          "type": "select",
          "required": true,
          "code": "Accuracy?A",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "choices": {
            "0.0": "0%",
            "1.00": "100%",
            ".945": "90-99%",
            ".8": "70-90%",
            ".6": "50-70%",
            ".5": "50%",
            ".4": "30-50%",
            ".2": "10-30%",
            ".05": "1-10%"
          }
        }
      ]
    },
    {
      "name": "Teleop",
      "color": "#bf9000",
      "fields": [
        {
          "title": "Hub Fuel",
          "type": "multi-counter",
          "required": false,
          "code": "hubAuto",
          "formResetBehavior": "reset",
          "defaultValue": 0
        },
        {
          "title": "Ferried Fuel",
          "type": "multi-counter",
          "required": false,
          "code": "ferAuto",
          "formResetBehavior": "reset",
          "defaultValue": 0
        },
        {
          "title": "Ferry Type",
          "type": "select",
          "required": true,
          "code": "ferryTypeAuto",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "choices": {
            "None": "None",
            "Push": "Push",
            "Shoot": "Shoot",
            "Both": "Both"
          }
        },
        {
          "title": "Ferry Effectiveness",
          "type": "select",
          "required": true,
          "code": "ferryEffAuto",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "choices": {
            "None": "None",
            "Ineffective": "Ineffective",
            "Somewhat Effective": "Somewhat Effective",
            "Effective": "Effective",
            "Very Effective": "Very Effective"
          }
        },
        {
          "title": "Hub Fuel Accuracy",
          "type": "select",
          "required": true,
          "code": "Accuracy?C",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "choices": {
            "0.0": "0%",
            "1.00": "100%",
            ".945": "90-99%",
            ".8": "70-90%",
            ".6": "50-70%",
            ".5": "50%",
            ".4": "30-50%",
            ".2": "10-30%",
            ".05": "1-10%"
          }
        }
      ]
    },
    {
      "name": "Postmatch",
      "color": "#2a8525",
      "fields": [
        {
          "title": "Climb",
          "type": "select",
          "required": true,
          "code": "endPos",
          "formResetBehavior": "reset",
          "defaultValue": "No Climb",
          "choices": {
            "No Climb": "No Climb",
            "Failed Climb": "Failed Climb",
            "L1": "L1 Climb",
            "L2": "L2 Climb",
            "L3": "L3 Climb"
          }
        },
        {
          "title": "Crossed Trench?",
          "type": "boolean",
          "required": false,
          "code": "CFPDT",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Crossed Bump?",
          "type": "select",
          "required": true,
          "code": "Bump?C",
          "formResetBehavior": "reset",
          "defaultValue": "Did Not Cross",
          "choices": {
            "Did Not Cross": "Did Not Cross",
            "Got stuck": "Got stuck",
            "Difficulties": "Had Some Difficulties",
            "Crossed Well": "Crossed Well"
          }
        },
        {
          "title": "Issues during Match",
          "type": "select",
          "required": true,
          "code": "IdM",
          "formResetBehavior": "reset",
          "defaultValue": "No Problems",
          "choices": {
            "No Problems": "No Problems",
            "Died and Stayed Dead": "Died and Stayed Dead",
            "Died and Came Back": "Died and Came Back",
            "Fell Over": "Fell Over",
            "Brown Out": "Brown Out",
            "Other Mechanical Issue": "Other Mechanical Issue"
          }
        },
        {
          "title": "Defensive Skill",
          "type": "select",
          "required": true,
          "code": "DefSkill",
          "formResetBehavior": "reset",
          "defaultValue": "No Defense",
          "choices": {
            "No Defense": "No Defense",
            "WAY Below Average": "WAY Below Average",
            "Below Average": "Below Average",
            "Average": "Average",
            "Above Average": "Above Average",
            "WAY Above Average": "WAY Above Average"
          }
        },
        {
          "title": "Being Defended?",
          "type": "boolean",
          "required": false,
          "code": "CFPDT",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Percent Total Teleop Fuel",
          "description": "What percentage of the total fuel scored in teleop was scored by this robot",
          "type": "select",
          "required": true,
          "code": "TF%",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "choices": {
            "0.0": "0%",
            "1.00": "100%",
            ".945": "90-99%",
            ".8": "70-90%",
            ".6": "50-70%",
            ".5": "50%",
            ".4": "30-50%",
            ".2": "10-30%",
            ".05": "1-10%"
          }
        },
        {
          "title": "Comments!",
          "type": "text",
          "required": true,
          "code": "comments",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "min": 0,
          "max": 800
        }
      ]
    }
  ]
}